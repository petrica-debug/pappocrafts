# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Resend (email)
RESEND_API_KEY=re_...

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Google Analytics (GA4)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Ads Conversion Tracking
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=xxxxxxxxxxxxxxxx

# Facebook (Meta) Pixel
NEXT_PUBLIC_FB_PIXEL_ID=1234567890123456

# Google Search Console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-code

# Cloudflare Turnstile (bot protection on “List a product / Offer a service” modal)
# https://dash.cloudflare.com/ → Turnstile → create widget → hostnames: your production domain + localhost
# Replace with your own site key + secret; site key and secret must be from the same widget or verification fails.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Sentry Error Tracking
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# External API (for third-party platform integrations)
EXTERNAL_API_KEY=your-secret-api-key-here
